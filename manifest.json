{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "version": "2.9.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "linkscout@paulista.dev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "48": "icons/linkscout-48.svg"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "bookmarks",
    "notifications",
    "storage",
    "tabs",
    "alarms",
    "<all_urls>"
  ],
  "sidebar_action": {
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "icons/linkscout-48.svg",
    "default_title": "__MSG_sidebarTitle__",
    "open_at_install": false
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "__MSG_toggleSidebarShortcut__"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_icon": "icons/linkscout-48.svg",
    "default_title": "__MSG_browserActionTooltip__"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}